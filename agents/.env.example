PORT=8787
CORS_ORIGIN=http://localhost:3000

# OpenRouter — powers planner / specialist agent reasoning
OPEN_ROUTER_API=sk-or-v1-your-key
OPEN_ROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Solana devnet agent wallet (funds rent payouts & receives hire escrow)
AGENT_WALLET_PRIVATE_KEY=your-base58-or-json-array-secret-key
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# CoralOS — multi-agent orchestration (demo presentation layer)
CORAL_SERVER_URL=http://localhost:5555
CORAL_SESSION_TTL_MINUTES=60

# Small real devnet amounts (keep low for demos)
RENT_PAYOUT_SOL=0.001
HIRE_MIN_BUDGET_SOL=0.001
HIRE_MAX_BUDGET_SOL=0.05
